---
export interface Props {
  title: string;
  description?: string;
  activeTab?: string;
}

const { title, description, activeTab } = Astro.props;

const tabs = [
  { label: 'Home', href: '/' },
  { label: 'Chemistry', href: '/subjects/chemistry' },
  { label: 'Biology', href: '/subjects/biology' },
  { label: 'Physics', href: '/subjects/physics' },
  { label: 'Field Trips', href: '/subjects/field-trips' },
  { label: 'Lab Activities', href: '/subjects/lab-activities' },
  { label: 'Science Club', href: '/subjects/science-club' },
  { label: 'Archaeology', href: '/subjects/archaeology' },
  { label: 'CV', href: '/cv' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'Science teacher portfolio'} />
    <title>{title} | Science Portfolio</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-title">Science Portfolio</a>
        <p class="site-subtitle">Exploring the wonders of science with students</p>
      </div>
      <nav class="site-nav" aria-label="Main navigation">
        <ul class="nav-tabs">
          {tabs.map((tab) => (
            <li>
              <a
                href={tab.href}
                class={tab.label === activeTab || (tab.href === '/' && Astro.url.pathname === '/') || (tab.href !== '/' && Astro.url.pathname.startsWith(tab.href)) ? 'active' : ''}
              >
                {tab.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Science Portfolio. Built with care for science education.</p>
    </footer>
  </body>
</html>
