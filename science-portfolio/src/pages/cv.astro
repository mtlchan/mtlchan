---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CV" activeTab="CV">
  <div class="cv-page">
    <h1>Curriculum Vitae</h1>
    <p class="cv-subtitle">Science Educator</p>

    <section class="cv-section">
      <h2>Education</h2>
      <div class="cv-entry">
        <h3>Master of Science in Education</h3>
        <p class="cv-date">[University Name] &mdash; [Year]</p>
        <p>Specialization in science curriculum development and inquiry-based pedagogy.</p>
      </div>
      <div class="cv-entry">
        <h3>Bachelor of Science in Chemistry</h3>
        <p class="cv-date">[University Name] &mdash; [Year]</p>
        <p>Minor in biology. Graduated with honors.</p>
      </div>
    </section>

    <section class="cv-section">
      <h2>Teaching Experience</h2>
      <div class="cv-entry">
        <h3>Science Teacher</h3>
        <p class="cv-date">[School Name] &mdash; [Year] &ndash; Present</p>
        <p>
          Teach chemistry, biology, and physics to grades 9&ndash;12. Develop and implement
          inquiry-based lab curricula. Advisor for the Science Club and coordinator for
          annual science fair participation.
        </p>
      </div>
      <div class="cv-entry">
        <h3>Student Teacher</h3>
        <p class="cv-date">[School Name] &mdash; [Year]</p>
        <p>
          Completed teaching practicum in chemistry and general science. Designed lesson
          plans, led classroom instruction, and assessed student progress under mentor supervision.
        </p>
      </div>
    </section>

    <section class="cv-section">
      <h2>Certifications</h2>
      <div class="cv-entry">
        <h3>State Teaching License — Secondary Science</h3>
        <p class="cv-date">[State] Department of Education &mdash; [Year]</p>
        <p>Certified to teach chemistry, biology, and general science (grades 7&ndash;12).</p>
      </div>
      <div class="cv-entry">
        <h3>Laboratory Safety Certification</h3>
        <p class="cv-date">[Issuing Organization] &mdash; [Year]</p>
        <p>Certified in chemical hygiene, lab safety management, and hazardous material handling.</p>
      </div>
    </section>

    <section class="cv-section">
      <h2>Skills</h2>
      <p>
        <strong>Laboratory Techniques:</strong> Titration, spectrophotometry, microscopy, gel electrophoresis,
        circuit assembly, dissection techniques.
      </p>
      <p>
        <strong>Instructional:</strong> Inquiry-based learning, differentiated instruction, project-based
        assessment, classroom management, curriculum design, lab safety instruction.
      </p>
      <p>
        <strong>Technology:</strong> Interactive whiteboard tools, learning management systems (Google Classroom,
        Canvas), data analysis software (Excel, Logger Pro), basic Python for data visualization.
      </p>
      <p>
        <strong>Languages:</strong> English (native), [additional languages if applicable].
      </p>
    </section>

    <section class="cv-section">
      <h2>Contact</h2>
      <p>
        <strong>Email:</strong> <a href="mailto:teacher@example.com">teacher@example.com</a>
      </p>
      <p>
        <strong>School:</strong> [School Name], [Address]
      </p>
      <p>
        <strong>Phone:</strong> [School phone number]
      </p>
    </section>
  </div>
</Layout>
